  <property name="styleSheet">
   <string notr="true">/* Configuración del Diálogo Principal */
QDialog {
    background-color: #ffffff; /* Fondo blanco puro para limpieza */
}

/* Etiquetas (QLabel) */
QLabel {
    color: #555555;
    font-size: 18pt;
    font-weight: 500;
    background: transparent;
}

/* Campos de Texto (QLineEdit) */
QLineEdit {
    background-color: #fdf2f5; /* Rosa muy tenue */
    border: 1px solid #f2d1da;
    border-radius: 8px; /* Bordes suaves */
    padding: 8px 12px;
    color: #333333;
    font-size: 18pt;
}

QLineEdit:focus {
    border: 2px solid #f06292; /* Resalte en rosa más intenso al escribir */
    background-color: #ffffff;
}

/* Botones (QPushButton) */
QPushButton {
    background-color: #fce4ec; /* Fondo rosa pastel */
    color: #d81b60; /* Texto rosa fuerte para contraste */
    border: none;
    border-radius: 10px;
    padding: 10px 20px;
    font-size: 18pt;
    font-weight: bold;
    min-width: 120px;
}

QPushButton:hover {
    background-color: #f8bbd0; /* Se oscurece ligeramente al pasar el mouse */
}

QPushButton:pressed {
    background-color: #f48fb1; /* Efecto de pulsado */
    color: #ffffff;
}

QPushButton:disabled {
    background-color: #eeeeee;
    color: #bdbdbd;
}</string>
